# === Secrets — NEVER commit the real .env file ===

# Exchange API keys (read-only permissions sufficient for data)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Polymarket (derive API creds from private key via client.derive_api_key())
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1              # 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE

# Polymarket Relayer (gas-free claims — optional, for --live mode)
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com

# Polygon RPC (Alchemy or QuickNode)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_FALLBACK_URL=

# Database
TIMESCALEDB_URL=postgresql://qm:qm@127.0.0.1:5432/qm

# Monitoring
ALERT_SLACK_WEBHOOK_URL=
