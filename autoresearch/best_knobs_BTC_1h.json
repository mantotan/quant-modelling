    ]
  },
  "regime_params": {
    "enabled": true,
    "vol_window": 120,
    "lookback_window": 120,
    "low_percentile": 25.0,
    "high_percentile": 75.0,
    "crisis_percentile": 95.0,
    "trend_window": 20
  },
  "objective": {
    "primary": "brier",
    "brier_threshold": 0.20,
    "brier_penalty_weight": 10.0,
    "min_trades": 50,
    "trade_penalty_weight": 5.0,
    "max_drawdown_threshold": 0.30,
    "drawdown_penalty_weight": 5.0
  },
  "feature_selection": {
    "missing_threshold": 0.5,
    "min_target_corr": 0.005,
    "max_pairwise_corr": 0.90,
    "min_features_fallback": 5,
    "protected_prefixes": [
      "funding_", "liquidation_", "leverage_", "oi_",
      "regime_", "iv_", "pm_",
      "funding_x_", "oi_div_x_", "iv_skew_x_",
      "leverage_x_", "regime_x_", "btc_lead_x_", "pm_imbalance_x_"
    ]
  },
  "time_pcts": [0.10, 0.20, 0.40, 0.60, 0.80],
  "hpo_search_space": {
    "n_estimators": [100, 350],
    "learning_rate": [0.005, 0.05],
    "max_depth": [2, 6],
    "num_leaves": [32, 96],
    "min_child_samples": [100, 1000],
    "subsample": [0.6, 0.9],
    "colsample_bytree": [0.4, 0.8],
    "reg_alpha": [1e-8, 10.0],
    "reg_lambda": [1e-8, 10.0]
  },
  "walk_forward": {
    "n_splits": 8,
    "train_bars": 10000,
    "test_bars": 2000,
    "purge_period": 24,
    "embargo_period": 6
