{
  "exclude_features": [
    "return_1",
    "log_return_1",
    "gap"
  ],
  "feature_selection": {
    "missing_threshold": 0.5,
    "min_target_corr": 0.005,
    "max_pairwise_corr": 0.9,
    "min_features_fallback": 5
  },
  "hpo_search_space": {
    "n_estimators": [
      50,
      1000
    ],
    "learning_rate": [
      0.005,
      0.1
    ],
    "max_depth": [
      2,
      8
    ],
    "num_leaves": [
      7,
      127
    ],
    "min_child_samples": [
      50,
      500
    ],
    "subsample": [
      0.5,
      1.0
    ],
    "colsample_bytree": [
      0.3,
      1.0
    ],
    "reg_alpha": [
      1e-08,
      10.0
    ],
    "reg_lambda": [
      1e-08,
      10.0
    ],
    "min_split_gain": [
      0.0,
      1.0
    ]
  },
  "walk_forward": {
    "n_splits": 5,
    "purge_period": 24,
    "embargo_period": 12
  },
  "backtest": {
    "fee_bps": 0.0,
    "spread": 0.02,
    "min_edge": 0.01,
    "kelly_fraction": 0.25,
    "initial_bankroll": 10000.0
  },
  "cross_asset": {
    "enabled": true,
    "features": [
      "btc_distance_from_open",
      "btc_vol_norm_distance",
      "btc_partial_range",
      "btc_partial_bar_position"
    ]
  },
  "specialist": {
    "enabled": false,
    "boundary": 0.4,
    "early_time_pcts": [
      0.1,
      0.2
    ],
    "late_time_pcts": [
      0.4,
      0.6,
      0.8
    ]
  }
}